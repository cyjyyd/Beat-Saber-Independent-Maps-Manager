<Window xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         x:Class="BSIMM.Avalonia.Views.PresetEditorWindow"
         Title="筛选预设编辑器" Width="960" Height="720"
         Icon="/Assets/aa2yv-q2dg9-001.ico"
         WindowStartupLocation="CenterOwner"
         Background="{DynamicResource AppBackgroundBrush}"
         Foreground="{DynamicResource TextPrimaryBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#F4F7FC</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackgroundBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#D5DDEB</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimaryBrush">#1A1E24</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondaryBrush">#5A6A85</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightBlueBrush">#0078D4</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightRedBrush">#E81123</SolidColorBrush>
                    <SolidColorBrush x:Key="ButtonHoverBrush">#E4E9F2</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#0B0E14</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackgroundBrush">#12161E</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#1C2433</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimaryBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondaryBrush">#8E9EBC</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightBlueBrush">#00D2FF</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightRedBrush">#FF1B51</SolidColorBrush>
                    <SolidColorBrush x:Key="ButtonHoverBrush">#253246</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="预设：" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBox Name="TxtPresetName" MinWidth="160" VerticalAlignment="Center" />
                <ComboBox Name="CboPreset" MinWidth="140" VerticalAlignment="Center" PlaceholderText="加载已有..." />
                <Button Content="保存" Click="OnSavePresetClick" MinWidth="60" />
                <Button Content="删除" Click="OnDeletePresetClick" MinWidth="60" />
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0" />
                <Button Content="导入旧预设..." Click="OnImportLegacyClick" MinWidth="100" />
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0" />
                <Button Content="新建" Click="OnNewPresetClick" MinWidth="60" Classes="bs-blue" />
                <CheckBox Name="ChkLocalCache" Content="本地缓存" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="{DynamicResource HighlightBlueBrush}" />
            </StackPanel>
        </Border>

        <!-- Filter Summary -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
            <TextBlock Name="LblFilterSummary" Text="当前筛选：无" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
        </Border>

        <!-- Main Content: Conditions List -->
        <ScrollViewer Grid.Row="2" Padding="12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <!-- Empty placeholder -->
                <Border Name="EmptyPlaceholder" Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                        Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="还没有筛选条件" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="从下方下拉框选择条件类型开始构建" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Conditions Panel -->
                <StackPanel Name="ConditionsPanel" Spacing="6" />

                <!-- Add Condition Row -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <TextBlock Text="+ 添加条件：" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox Name="CboAddCondition" MinWidth="240" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Output Config Section -->
                <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,8,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="输出配置" FontWeight="Bold" Foreground="{DynamicResource HighlightBlueBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox Name="ChkLimit" Content="限制数量:" VerticalAlignment="Center" />
                            <TextBox Name="NumLimit" Text="100" VerticalAlignment="Center" MinWidth="80" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox Name="ChkPlaylist" Content="导出歌单:" VerticalAlignment="Center" />
                            <TextBox Name="TxtPlaylistDir" MinWidth="300" VerticalAlignment="Center" IsReadOnly="True" />
                            <Button Content="浏览..." Click="OnBrowsePlaylistClick" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox Name="ChkDownload" Content="下载歌曲:" VerticalAlignment="Center" />
                            <TextBox Name="TxtDownloadDir" MinWidth="300" VerticalAlignment="Center" IsReadOnly="True" />
                            <Button Content="浏览..." Click="OnBrowseDownloadClick" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="实时预览(本地)" Click="OnPreviewClick" Width="120" />
                <TextBlock Name="LblMatchCount" Text="" VerticalAlignment="Center" Foreground="{DynamicResource HighlightRedBrush}" FontWeight="Bold" Margin="0,0,20,0" />
                <Button Content="取消" Click="OnCancelClick" Width="80" />
                <Button Content="执行筛选" Click="OnExecuteClick" Classes="bs-blue" Width="100" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
