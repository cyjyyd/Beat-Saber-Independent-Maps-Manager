<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BSIMM.Avalonia.Views.FilterBuilderWindow"
        Title="筛选条件构建器" Width="960" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#F4F7FC</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackgroundBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#D5DDEB</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimaryBrush">#1A1E24</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondaryBrush">#5A6A85</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightBlueBrush">#0078D4</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightRedBrush">#E81123</SolidColorBrush>
                    <SolidColorBrush x:Key="ButtonHoverBrush">#E4E9F2</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#0B0E14</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackgroundBrush">#12161E</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#1C2433</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimaryBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondaryBrush">#8E9EBC</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightBlueBrush">#00D2FF</SolidColorBrush>
                    <SolidColorBrush x:Key="HighlightRedBrush">#FF1B51</SolidColorBrush>
                    <SolidColorBrush x:Key="ButtonHoverBrush">#253246</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Preset Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="预设：" VerticalAlignment="Center" FontWeight="Bold" />
                <ComboBox Name="CboPreset" MinWidth="180" VerticalAlignment="Center" />
                <Button Content="保存" Click="OnSavePresetClick" MinWidth="60" />
                <Button Content="另存为" Click="OnSaveAsPresetClick" MinWidth="70" />
                <Button Content="删除" Click="OnDeletePresetClick" MinWidth="60" />
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0" />
                <Button Content="导入" Click="OnImportPresetClick" MinWidth="60" />
                <Button Content="导出" Click="OnExportPresetClick" MinWidth="60" />
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,0" />
                <Button Content="新建" Click="OnNewPresetClick" MinWidth="60" Classes="bs-blue" />
                <Button Content="添加条件组" Click="OnAddGroupClick" Classes="bs-blue" MinWidth="100" />
            </StackPanel>
        </Border>

        <!-- Filter Summary -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
            <TextBlock Name="LblFilterSummary" Text="当前筛选：无" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
        </Border>

        <!-- Main Content: Groups List -->
        <ScrollViewer Grid.Row="2" Padding="12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Name="GroupsPanel" Spacing="12">
                <!-- Placeholder when empty -->
                <Border Name="EmptyPlaceholder" Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                        Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="还没有条件组" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="点击上方「添加条件组」开始构建筛选条件" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <Button Content="添加条件组" Click="OnAddGroupClick" Classes="bs-blue" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="取消" Click="OnCancelClick" Width="80" />
                <Button Content="搜索" Click="OnSearchClick" Classes="bs-blue" Width="100" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
