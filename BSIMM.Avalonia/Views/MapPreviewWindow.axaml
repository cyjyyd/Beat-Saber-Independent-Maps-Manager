<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BSIMM.Avalonia.Views.MapPreviewWindow"
        Title="谱面预览 (ArcViewer)" Width="1024" Height="768"
        Icon="/Assets/aa2yv-q2dg9-001.ico"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        Foreground="#FFFFFF">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Loading/Status Bar -->
        <Border Grid.Row="0" Background="#16213e" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Name="LblStatus" Text="正在加载 ArcViewer..." VerticalAlignment="Center" Foreground="#8E9EBC" FontSize="13" />
                <ProgressBar Name="LoadProgress" IsIndeterminate="True" Width="120" IsVisible="True" />
            </StackPanel>
        </Border>
        <!-- WebView Container -->
        <Border Grid.Row="1" Background="#000000" ClipToBounds="True">
            <Panel Name="WebViewContainer" />
        </Border>
        <!-- Bottom Close Button -->
        <Border Grid.Row="2" Background="#16213e" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <TextBlock Text="由 ArcViewer 提供预览 (allpoland.github.io/ArcViewer)" VerticalAlignment="Center" Foreground="#4B6082" FontSize="11" />
                <Button Content="关闭" Click="OnCloseClick" Width="80" HorizontalContentAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
